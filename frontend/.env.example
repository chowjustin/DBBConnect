# Backend API base. lib/api.ts appends "/api" automatically.
# Do NOT include /api suffix here.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used for metadata.metadataBase and absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mount /sandbox route showing color, typography and component gallery.
# Gated by this flag in any environment. Default false.
NEXT_PUBLIC_SHOW_SANDBOX=false

# Force logger() output in prod (always on in dev regardless).
NEXT_PUBLIC_SHOW_LOGGER=false
